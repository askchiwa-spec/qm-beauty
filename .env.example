# Environment variables for QMBeauty production
# Copy this file to .env and update with your actual values

# Database
DB_PASSWORD=your_secure_database_password_here

# Selcom Payment Gateway
SELCOM_API_KEY=your_selcom_api_key
SELCOM_API_SECRET=your_selcom_api_secret
SELCOM_VENDOR_ID=your_selcom_vendor_id

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=https://www.qmbeauty.africa

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://www.qmbeauty.africa